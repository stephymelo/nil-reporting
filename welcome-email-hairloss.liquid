                  </td>
                  <td style="padding:0 10px; font-family:'Helvetica Neue', Helvetica, Arial, sans-serif; font-size:11px; font-weight:600; letter-spacing:0.07em; text-transform:uppercase;">
                    <a href="{{ shop.url }}/policies/privacy-policy" style="color:#8a84b0; text-decoration:none;">Privacy</a>
                  </td>
                  <td style="padding:0 10px; font-family:'Helvetica Neue', Helvetica, Arial, sans-serif; font-size:11px; font-weight:600; letter-spacing:0.07em; text-transform:uppercase;">
                    <a href="{{ shop.url }}/pages/contact" style="color:#8a84b0; text-decoration:none;">Contact</a>
                  </td>
                </tr>

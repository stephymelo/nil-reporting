            <td align="center" class="mobile-px" style="background:#2a2040; padding:36px 40px;">
              <p style="margin:0 0 14px 0; font-family:'Helvetica Neue', Helvetica, Arial, sans-serif; font-size:17px; font-weight:700; color:#d6cfeb;">{{ shop.name }}</p>
              <p style="margin:0 0 4px 0; font-family:'Helvetica Neue', Helvetica, Arial, sans-serif; font-size:12px; color:#8a84b0; line-height:1.7;">© {{ 'now' | date: '%Y' }} {{ shop.name }} — All rights reserved.</p>
              <p style="margin:0 0 16px 0; font-family:'Helvetica Neue', Helvetica, Arial, sans-serif; font-size:12px; color:#8a84b0; line-height:1.7;">

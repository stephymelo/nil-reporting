                      <tr>
                        <td class="col-card" align="center" style="background:#d6cfeb; border-radius:4px; padding:24px 20px;">
                          <a href="{{ shop.url }}/collections/for-women" style="text-decoration:none; display:block;">
                            <p style="margin:0 0 5px 0; font-family:'Helvetica Neue', Helvetica, Arial, sans-serif; font-size:11px; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:#2a2040;">For Women</p>
                            <p style="margin:0; font-family:'Helvetica Neue', Helvetica, Arial, sans-serif; font-size:12px; color:#6b6490; line-height:1.4;">Wigs, toppers &amp; more</p>
                          </a>
                        </td>
                      </tr>
                    </table>

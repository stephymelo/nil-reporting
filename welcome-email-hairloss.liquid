                    <a href="{{ shop.url }}/collections/hair-system-application" style="color:#3d3060; text-decoration:none;">Application</a>
                  </td>
                  <td class="nav-link" style="padding:14px 14px; font-family:'Helvetica Neue', Helvetica, Arial, sans-serif; font-size:10.5px; font-weight:600; letter-spacing:0.08em; text-transform:uppercase;">
                    <a href="{{ shop.url }}/collections/accessories-hair-care" style="color:#3d3060; text-decoration:none;">Hair Care</a>

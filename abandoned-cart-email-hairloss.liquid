<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml" xmlns:v="urn:schemas-microsoft-com:vml" xmlns:o="urn:schemas-microsoft-com:office:office" lang="en">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="format-detection" content="telephone=no, date=no, address=no, email=no">
  <meta name="color-scheme" content="light">
  <meta name="supported-color-schemes" content="light">
  <title>You left something behind at {{ shop.name }}</title>

  <!--[if mso]>
  <noscript>
    <xml>
      <o:OfficeDocumentSettings>
        <o:PixelsPerInch>96</o:PixelsPerInch>
      </o:OfficeDocumentSettings>
    </xml>
  </noscript>
  <style>
    table, td, div, h1, h2, p, a { font-family: Arial, Helvetica, sans-serif !important; }
    .btn-link { padding: 0 !important; }
  </style>
  <![endif]-->

  <style type="text/css">
    /* CLIENT RESETS */
    body, table, td, a { -webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; }
    table, td { mso-table-lspace: 0pt; mso-table-rspace: 0pt; }
    img { -ms-interpolation-mode: bicubic; border: 0; height: auto; line-height: 100%; outline: none; text-decoration: none; display: block; }
    table { border-collapse: collapse !important; }
    body { height: 100% !important; margin: 0 !important; padding: 0 !important; width: 100% !important; background: #f2f2f2; }
    a[x-apple-data-detectors] { color: inherit !important; text-decoration: none !important; }
    a { color: #2a2040; text-decoration: none; }

    /* MOBILE */
    @media screen and (max-width: 620px) {
      .email-container { width: 100% !important; max-width: 100% !important; }
      .mobile-px { padding-left: 24px !important; padding-right: 24px !important; }
      .mobile-py-hero { padding-top: 40px !important; padding-bottom: 36px !important; }
      .mobile-py-section { padding-top: 36px !important; padding-bottom: 36px !important; }
      .hero-title { font-size: 28px !important; line-height: 1.2 !important; }
      .section-title { font-size: 20px !important; }
      .nav-link { padding: 10px 8px !important; font-size: 10px !important; }
      .col-card { display: block !important; width: 100% !important; padding: 20px !important; }
      .col-card-wrap { padding-bottom: 10px !important; }
      .coupon-box { padding: 14px 24px !important; }
      .coupon-code { font-size: 24px !important; }
      .cart-img-cell { width: 72px !important; }
      .cart-img { width: 72px !important; }
      .cart-item-title { font-size: 13px !important; }
      .cart-item-price { font-size: 13px !important; }
    }
  </style>
</head>

<body style="margin:0; padding:0; background:#f2f2f2; -webkit-font-smoothing:antialiased;">

  <!-- PREHEADER -->
  <div style="display:none; font-size:1px; color:#f2f2f2; line-height:1px; max-height:0px; max-width:0px; opacity:0; overflow:hidden; mso-hide:all;">
    {%- if abandoned_checkout.customer.first_name != blank -%}{{ abandoned_checkout.customer.first_name }}, your{%- else -%}Your{%- endif -%} cart is still saved — come back and complete your order.&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;
  </div>

  <!-- OUTER WRAPPER -->
  <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="background:#f2f2f2;">
    <tr>
      <td align="center" style="padding:0;">

        <!-- EMAIL CONTAINER -->
        <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="620" class="email-container" style="width:620px; max-width:620px; background:#ffffff;">

          <!-- NAV -->
          <tr>
            <td align="center" style="background:#ffffff; border-bottom:1px solid #ede9f8; padding:4px 12px;">
              <table role="presentation" cellspacing="0" cellpadding="0" border="0">
                <tr>
                  <td class="nav-link" style="padding:14px 14px; font-family:'Helvetica Neue', Helvetica, Arial, sans-serif; font-size:10.5px; font-weight:600; letter-spacing:0.08em; text-transform:uppercase;">
                    <a href="https://hairloss.com/collections/wigs-and-toppers" style="color:#3d3060; text-decoration:none;">For Women</a>
                  </td>
                  <td class="nav-link" style="padding:14px 14px; font-family:'Helvetica Neue', Helvetica, Arial, sans-serif; font-size:10.5px; font-weight:600; letter-spacing:0.08em; text-transform:uppercase;">
                    <a href="https://hairloss.com/collections/hair-systems-men" style="color:#3d3060; text-decoration:none;">For Men</a>
                  </td>
                  <td class="nav-link" style="padding:14px 14px; font-family:'Helvetica Neue', Helvetica, Arial, sans-serif; font-size:10.5px; font-weight:600; letter-spacing:0.08em; text-transform:uppercase;">
                    <a href="https://hairloss.com/collections/hair-system-application" style="color:#3d3060; text-decoration:none;">Application</a>
                  </td>
                  <td class="nav-link" style="padding:14px 14px; font-family:'Helvetica Neue', Helvetica, Arial, sans-serif; font-size:10.5px; font-weight:600; letter-spacing:0.08em; text-transform:uppercase;">
                    <a href="https://hairloss.com/collections/hair-scalp-care" style="color:#3d3060; text-decoration:none;">Hair Care</a>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- HERO -->
          <tr>
            <td align="center" class="mobile-px mobile-py-hero" style="background:#d6cfeb; background:linear-gradient(160deg, #e3ebf7 0%, #d6cfeb 100%); padding:52px 40px 44px;">
              <p style="margin:0 0 14px 0; font-family:'Helvetica Neue', Helvetica, Arial, sans-serif; font-size:11px; font-weight:600; letter-spacing:0.15em; text-transform:uppercase; color:#7a6eb0;">You left something behind</p>

              <h1 class="hero-title" style="margin:0 0 16px 0; font-family:'Helvetica Neue', Helvetica, Arial, sans-serif; font-size:34px; font-weight:700; color:#1e1635; line-height:1.2; letter-spacing:-0.5px;">
                Your cart is<br>waiting for you.
              </h1>

              <p style="margin:0 auto 28px auto; max-width:440px; font-family:'Helvetica Neue', Helvetica, Arial, sans-serif; font-size:15px; color:#4a4070; line-height:1.65;">
                Great news — your items are still saved. Come back and complete your order.
              </p>

              <!-- RETURN TO CART BUTTON -->
              <table role="presentation" cellspacing="0" cellpadding="0" border="0" align="center" style="margin:0 auto;">
                <tr>
                  <td align="center" style="border-radius:3px; background:#2a2040;">
                    <a href="{{ abandoned_checkout.url }}" style="display:inline-block; padding:14px 36px; font-family:'Helvetica Neue', Helvetica, Arial, sans-serif; font-size:13px; font-weight:600; letter-spacing:0.08em; text-transform:uppercase; color:#ffffff; text-decoration:none; border-radius:3px; background:#2a2040;">
                      <!--[if mso]>&nbsp;&nbsp;&nbsp;&nbsp;<![endif]-->
                      Return to My Cart
                      <!--[if mso]>&nbsp;&nbsp;&nbsp;&nbsp;<![endif]-->
                    </a>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- CART ITEMS -->
          <tr>
            <td class="mobile-px mobile-py-section" style="padding:44px 40px 28px; background:#ffffff;">
              <p style="margin:0 0 10px 0; text-align:center; font-family:'Helvetica Neue', Helvetica, Arial, sans-serif; font-size:10px; font-weight:700; letter-spacing:0.18em; text-transform:uppercase; color:#a09ac8;">Still in your cart</p>
              <h2 class="section-title" style="margin:0 0 28px 0; text-align:center; font-family:'Helvetica Neue', Helvetica, Arial, sans-serif; font-size:22px; font-weight:700; color:#1e1635; letter-spacing:-0.3px;">
                {%- if abandoned_checkout.line_items_count == 1 -%}
                  Your saved item
                {%- else -%}
                  Your saved items
                {%- endif -%}
              </h2>

              {% if abandoned_checkout.line_items.size > 0 %}
                <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="border-top:1px solid #ede9f8;">
                  {% for line in abandoned_checkout.line_items %}
                    <tr>
                      <td class="cart-img-cell" width="96" valign="top" style="padding:18px 16px 18px 0; border-bottom:1px solid #ede9f8;">
                        <a href="{{ line.product.url }}" style="text-decoration:none;">
                          <img src="{{ line | img_url: 'compact', scale: 2 }}" width="90" alt="{{ line.title | escape }}" class="cart-img" style="display:block; width:90px; max-width:90px; height:auto; border-radius:4px; background:#f6f4fc; border:0;">
                        </a>
                      </td>
                      <td valign="top" style="padding:18px 12px 18px 0; border-bottom:1px solid #ede9f8;">
                        <a href="{{ line.product.url }}" style="text-decoration:none;">
                          <p class="cart-item-title" style="margin:0 0 4px 0; font-family:'Helvetica Neue', Helvetica, Arial, sans-serif; font-size:14px; font-weight:600; color:#1e1635; line-height:1.4;">{{ line.product.title }}</p>
                        </a>
                        {% if line.variant.title != 'Default Title' %}
                          <p style="margin:0 0 4px 0; font-family:'Helvetica Neue', Helvetica, Arial, sans-serif; font-size:12px; color:#6b6490; line-height:1.4;">{{ line.variant.title }}</p>
                        {% endif %}
                        <p style="margin:0; font-family:'Helvetica Neue', Helvetica, Arial, sans-serif; font-size:12px; color:#8a84b0;">Qty: {{ line.quantity }}</p>
                      </td>
                      <td valign="top" align="right" style="padding:18px 0 18px 0; border-bottom:1px solid #ede9f8;">
                        <p class="cart-item-price" style="margin:0; font-family:'Helvetica Neue', Helvetica, Arial, sans-serif; font-size:14px; font-weight:600; color:#1e1635; white-space:nowrap;">{{ line.final_line_price | money }}</p>
                      </td>
                    </tr>
                  {% endfor %}

                  <!-- SUBTOTAL -->
                  <tr>
                    <td colspan="2" style="padding:18px 0 6px 0; font-family:'Helvetica Neue', Helvetica, Arial, sans-serif; font-size:13px; font-weight:600; letter-spacing:0.05em; text-transform:uppercase; color:#4a4070;">Subtotal</td>
                    <td align="right" style="padding:18px 0 6px 0; font-family:'Helvetica Neue', Helvetica, Arial, sans-serif; font-size:16px; font-weight:700; color:#1e1635;">{{ abandoned_checkout.subtotal_price | money }}</td>
                  </tr>
                  <tr>
                    <td colspan="3" style="padding:6px 0 0 0; font-family:'Helvetica Neue', Helvetica, Arial, sans-serif; font-size:11px; color:#8a84b0;">Shipping and taxes calculated at checkout.</td>
                  </tr>
                </table>

                <!-- COMPLETE CHECKOUT BUTTON -->
                <table role="presentation" cellspacing="0" cellpadding="0" border="0" align="center" style="margin:32px auto 0 auto;">
                  <tr>
                    <td align="center" style="border-radius:3px; background:#2a2040;">
                      <a href="{{ abandoned_checkout.url }}" style="display:inline-block; padding:14px 36px; font-family:'Helvetica Neue', Helvetica, Arial, sans-serif; font-size:13px; font-weight:600; letter-spacing:0.08em; text-transform:uppercase; color:#ffffff; text-decoration:none; border-radius:3px; background:#2a2040;">
                        <!--[if mso]>&nbsp;&nbsp;&nbsp;&nbsp;<![endif]-->
                        Complete My Order
                        <!--[if mso]>&nbsp;&nbsp;&nbsp;&nbsp;<![endif]-->
                      </a>
                    </td>
                  </tr>
                </table>
              {% endif %}
            </td>
          </tr>

          <!-- DISCOUNT (first-order offer) -->
          <tr>
            <td align="center" class="mobile-px mobile-py-section" style="background:#e3ebf7; padding:40px 40px;">
              <p style="margin:0 0 10px 0; font-family:'Helvetica Neue', Helvetica, Arial, sans-serif; font-size:10px; font-weight:700; letter-spacing:0.18em; text-transform:uppercase; color:#7a6eb0;">New to {{ shop.name }}?</p>
              <h2 style="margin:0 0 10px 0; font-family:'Helvetica Neue', Helvetica, Arial, sans-serif; font-size:20px; font-weight:700; color:#1e1635;">Save 10% on your first order</h2>
              <p style="margin:0 0 24px 0; font-family:'Helvetica Neue', Helvetica, Arial, sans-serif; font-size:14px; color:#4a5070; line-height:1.6; max-width:440px;">If you haven't placed your first order with us yet, apply the code below at checkout to take 10% off.</p>

              <!-- COUPON BOX -->
              <table role="presentation" cellspacing="0" cellpadding="0" border="0" align="center" style="margin:0 auto 24px auto;">
                <tr>
                  <td class="coupon-box" align="center" style="border:2px dashed #7a6eb0; border-radius:4px; padding:16px 40px; background:#ffffff;">
                    <p style="margin:0 0 6px 0; font-family:'Helvetica Neue', Helvetica, Arial, sans-serif; font-size:10px; letter-spacing:0.15em; text-transform:uppercase; color:#9590be;">First-order code</p>
                    <p class="coupon-code" style="margin:0 0 6px 0; font-family:'Helvetica Neue', Helvetica, Arial, sans-serif; font-size:28px; font-weight:800; letter-spacing:0.12em; color:#2a2040;">WELCOME10</p>
                    <p style="margin:0; font-family:'Helvetica Neue', Helvetica, Arial, sans-serif; font-size:12px; color:#7a6eb0;">10% off your first order</p>
                  </td>
                </tr>
              </table>

              <!-- APPLY & CHECKOUT BUTTON -->
              <table role="presentation" cellspacing="0" cellpadding="0" border="0" align="center" style="margin:0 auto;">
                <tr>
                  <td align="center" style="border-radius:3px; background:#2a2040;">
                    <a href="{{ abandoned_checkout.url }}" style="display:inline-block; padding:13px 32px; font-family:'Helvetica Neue', Helvetica, Arial, sans-serif; font-size:12px; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:#ffffff; text-decoration:none; border-radius:3px; background:#2a2040;">
                      <!--[if mso]>&nbsp;&nbsp;&nbsp;&nbsp;<![endif]-->
                      Apply Code &amp; Check Out
                      <!--[if mso]>&nbsp;&nbsp;&nbsp;&nbsp;<![endif]-->
                    </a>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- COLLECTIONS GRID -->
          <tr>
            <td class="mobile-px mobile-py-section" style="background:#ffffff; padding:44px 40px;">
              <p style="margin:0 0 10px 0; text-align:center; font-family:'Helvetica Neue', Helvetica, Arial, sans-serif; font-size:10px; font-weight:700; letter-spacing:0.18em; text-transform:uppercase; color:#a09ac8;">Browse</p>
              <h2 class="section-title" style="margin:0 0 8px 0; text-align:center; font-family:'Helvetica Neue', Helvetica, Arial, sans-serif; font-size:22px; font-weight:700; color:#1e1635; letter-spacing:-0.3px;">Explore Our Collections</h2>
              <p style="margin:0 0 28px 0; text-align:center; font-family:'Helvetica Neue', Helvetica, Arial, sans-serif; font-size:14px; color:#6b6490; line-height:1.6;">Find exactly what you need — from full systems to application kits and care products.</p>

              <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
                <tr>
                  <td class="col-card-wrap" width="50%" valign="top" style="padding:0 6px 12px 0;">
                    <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
                      <tr>
                        <td class="col-card" align="center" style="background:#d6cfeb; border-radius:4px; padding:24px 20px;">
                          <a href="https://hairloss.com/collections/wigs-and-toppers" style="text-decoration:none; display:block;">
                            <p style="margin:0 0 5px 0; font-family:'Helvetica Neue', Helvetica, Arial, sans-serif; font-size:11px; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:#2a2040;">For Women</p>
                            <p style="margin:0; font-family:'Helvetica Neue', Helvetica, Arial, sans-serif; font-size:12px; color:#6b6490; line-height:1.4;">Wigs, toppers &amp; more</p>
                          </a>
                        </td>
                      </tr>
                    </table>
                  </td>
                  <td class="col-card-wrap" width="50%" valign="top" style="padding:0 0 12px 6px;">
                    <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
                      <tr>
                        <td class="col-card" align="center" style="background:#e3ebf7; border-radius:4px; padding:24px 20px;">
                          <a href="https://hairloss.com/collections/hair-systems-men" style="text-decoration:none; display:block;">
                            <p style="margin:0 0 5px 0; font-family:'Helvetica Neue', Helvetica, Arial, sans-serif; font-size:11px; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:#2a2040;">For Men</p>
                            <p style="margin:0; font-family:'Helvetica Neue', Helvetica, Arial, sans-serif; font-size:12px; color:#6b6490; line-height:1.4;">Toupees &amp; hair systems</p>
                          </a>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
                <tr>
                  <td class="col-card-wrap" width="50%" valign="top" style="padding:0 6px 0 0;">
                    <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
                      <tr>
                        <td class="col-card" align="center" style="background:#e3ebf7; border-radius:4px; padding:24px 20px;">
                          <a href="https://hairloss.com/collections/hair-system-application" style="text-decoration:none; display:block;">
                            <p style="margin:0 0 5px 0; font-family:'Helvetica Neue', Helvetica, Arial, sans-serif; font-size:11px; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:#2a2040;">Application</p>
                            <p style="margin:0; font-family:'Helvetica Neue', Helvetica, Arial, sans-serif; font-size:12px; color:#6b6490; line-height:1.4;">Adhesives, tapes &amp; tools</p>
                          </a>
                        </td>
                      </tr>
                    </table>
                  </td>
                  <td class="col-card-wrap" width="50%" valign="top" style="padding:0 0 0 6px;">
                    <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
                      <tr>
                        <td class="col-card" align="center" style="background:#d6cfeb; border-radius:4px; padding:24px 20px;">
                          <a href="https://hairloss.com/collections/hair-scalp-care" style="text-decoration:none; display:block;">
                            <p style="margin:0 0 5px 0; font-family:'Helvetica Neue', Helvetica, Arial, sans-serif; font-size:11px; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:#2a2040;">Hair Care</p>
                            <p style="margin:0; font-family:'Helvetica Neue', Helvetica, Arial, sans-serif; font-size:12px; color:#6b6490; line-height:1.4;">Shampoos &amp; styling</p>
                          </a>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

        </table>
        <!-- /EMAIL CONTAINER -->

      </td>
    </tr>
  </table>

</body>
</html>
